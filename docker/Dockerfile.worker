# syntax=docker/dockerfile:1.7
#
# Worker image for contextmatrix-runner.
#
# Pinning policy (CTXRUN-044):
#   - The base image is pinned by SHA256 digest (not the mutable
#     `:bookworm-slim` tag). Update the digest intentionally when rolling
#     Debian point releases.
#   - The Go toolchain tarball is downloaded over HTTPS and verified against
#     GO_SHA256 before extraction.
#   - Developer tools (gopls, golangci-lint) are pinned to exact tags.
#   - Claude Code is installed from npm at an exact version rather than via
#     the mutable `curl … | bash` installer.
#   - apt packages are installed from Debian's current pool; see
#     TODO(H27) below for the follow-up that moves to snapshot.debian.org.
#
# Multi-stage split (H27) is deferred: the worker image intentionally carries
# the Go toolchain, gopls, and golangci-lint at runtime because Claude Code
# invokes them interactively inside the container. Splitting the runtime off
# requires a separate image for lint/test workflows and is tracked for a
# follow-up card. Do NOT remove the single-stage layout in this PR.
FROM debian@sha256:4724b8cc51e33e398f0e2e15e18d5ec2851ff0c2280647e1310bc1642182655d
# ^ debian:bookworm-slim resolved on 2026-04-21. Refresh intentionally via
#   `docker pull debian:bookworm-slim && docker inspect --format='{{index .RepoDigests 0}}' debian:bookworm-slim`.

# Pinned toolchain versions. Override at build time with --build-arg if a
# newer release has been vetted (Makefile reads these from the environment
# so CI and local builds stay in lockstep).
ARG GO_VERSION=1.26.2
ARG GO_SHA256_AMD64=990e6b4bbba816dc3ee129eaeaf4b42f17c2800b88a2166c265ac1a200262282
ARG GO_SHA256_ARM64=c958a1fe1b361391db163a485e21f5f228142d6f8b584f6bef89b26f66dc5b23
ARG GOPLS_VERSION=v0.21.1
ARG GOLANGCI_LINT_VERSION=v2.11.4
# SHA256 of the golangci-lint installer script at GOLANGCI_LINT_VERSION.
# Captured on 2026-04-21. Update alongside GOLANGCI_LINT_VERSION; CI will
# fail closed if the installer ever mutates under a pinned tag.
ARG GOLANGCI_LINT_INSTALL_SHA256=edfa587f31bde70db161d1e5b783e086a1627d7e2f7c91de5f7cca79bcdf8631
ARG CLAUDE_CODE_VERSION=2.1.116
# NodeSource publishes rolling "setup_25.x" packages, so nodejs itself is
# pinned via the NodeSource apt repo; the installed package version tracks
# NodeSource's latest 25.x release. TODO(H27/H29): add an exact nodejs apt
# version pin (e.g. nodejs=25.9.0-1nodesource1) once NodeSource publishes a
# snapshot-style archive we can rely on for reproducibility.

# Use bash with pipefail for all RUN instructions so a pipe component
# failing mid-chain (e.g. the curl half of a `curl | sha256sum -c -`
# checksum verification) aborts the step instead of getting masked by a
# zero exit code from the final command.
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    PATH="/usr/local/go/bin:/home/user/go/bin:/home/user/.local/bin:${PATH}"

# Install system dependencies + Claude Code requirements.
# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash ca-certificates build-essential curl git jq \
      libgcc-s1 libstdc++6 openssh-client ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Node 25 to match contextmatrix's frontend build stage. NodeSource's
# setup_25.x script is executed via bash but all packages ultimately come
# from a signed apt repo (keyring added by the setup script).
# hadolint ignore=DL3008
RUN curl -fsSL https://deb.nodesource.com/setup_25.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# github-cli isn't in Debian's main repo — install from GitHub's apt source.
# hadolint ignore=DL3008
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
       > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Install Go. The tarball is SHA256-verified before extraction so a
# compromised CDN or MITM cannot substitute a malicious toolchain.
RUN set -eux; \
    ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/'); \
    case "$ARCH" in \
      amd64) GO_SHA256="${GO_SHA256_AMD64}" ;; \
      arm64) GO_SHA256="${GO_SHA256_ARM64}" ;; \
      *) echo "unsupported arch: $ARCH" >&2; exit 1 ;; \
    esac; \
    TARBALL="go${GO_VERSION}.linux-${ARCH}.tar.gz"; \
    curl -fsSL "https://go.dev/dl/${TARBALL}" -o "/tmp/${TARBALL}"; \
    echo "${GO_SHA256}  /tmp/${TARBALL}" | sha256sum -c -; \
    tar -C /usr/local -xzf "/tmp/${TARBALL}"; \
    rm -f "/tmp/${TARBALL}"

# Install gopls (Go language server for Claude Code LSP integration) at a
# pinned tag — never @latest.
RUN GOBIN=/usr/local/go/bin go install "golang.org/x/tools/gopls@${GOPLS_VERSION}"

# Install golangci-lint. The installer script is fetched at the pinned tag,
# its SHA256 verified, then piped to sh. Fetching `.../<tag>/install.sh`
# and pinning the content hash protects against both a tag mutation and a
# supply-chain compromise of the release branch.
RUN set -eux; \
    curl -sSfL "https://raw.githubusercontent.com/golangci/golangci-lint/${GOLANGCI_LINT_VERSION}/install.sh" \
      -o /tmp/golangci-lint-install.sh; \
    echo "${GOLANGCI_LINT_INSTALL_SHA256}  /tmp/golangci-lint-install.sh" | sha256sum -c -; \
    sh /tmp/golangci-lint-install.sh -b /usr/local/bin "${GOLANGCI_LINT_VERSION}"; \
    rm -f /tmp/golangci-lint-install.sh

# Install Claude Code CLI via npm at an exact version. Replaces the prior
# `curl … | bash` installer (REVIEW.md C15). The npm tarball integrity is
# verified by npm against the registry's published signatures. Run as root
# so the global install can write to /usr/lib/node_modules.
RUN npm install -g "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}"

# Copy entrypoint, make it executable, and create non-root user at UID
# 1000 (Debian slim has no default user at this UID). Combined into one
# RUN so hadolint DL3059 does not flag consecutive instructions.
COPY entrypoint.sh /entrypoint.sh
RUN chmod 755 /entrypoint.sh \
    && useradd -m -u 1000 -s /bin/bash user
USER user
WORKDIR /home/user

# No long-lived endpoint lives in this container; the worker is a one-shot
# batch process driven by the runner-side /trigger webhook. `HEALTHCHECK
# NONE` tells Docker (and tools like kubelet) to skip probing rather than
# leaving the default "no healthcheck" state, which some schedulers treat
# as perpetually unhealthy.
HEALTHCHECK NONE

ENTRYPOINT ["/entrypoint.sh"]
