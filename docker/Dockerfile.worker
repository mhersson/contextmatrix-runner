FROM debian:bookworm-slim

# Install system dependencies + Claude Code requirements.
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash curl git openssh-client ca-certificates build-essential jq \
      libgcc-s1 libstdc++6 ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Node 25 to match contextmatrix's frontend build stage.
RUN curl -fsSL https://deb.nodesource.com/setup_25.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# github-cli isn't in Debian's main repo — install from GitHub's apt source.
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
       > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Install Go.
ARG GO_VERSION=1.26.2
RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') && \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${ARCH}.tar.gz" \
    | tar -C /usr/local -xzf -
ENV PATH="/usr/local/go/bin:/home/user/go/bin:/home/user/.local/bin:${PATH}"

# Install gopls (Go language server for Claude Code LSP integration).
RUN GOBIN=/usr/local/go/bin go install golang.org/x/tools/gopls@latest

# Install golangci-lint.
ARG GOLANGCI_LINT_VERSION=v2.11.4
RUN curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/${GOLANGCI_LINT_VERSION}/install.sh \
    | sh -s -- -b /usr/local/bin ${GOLANGCI_LINT_VERSION}

# Copy entrypoint.
COPY entrypoint.sh /entrypoint.sh
RUN chmod 755 /entrypoint.sh

# Create non-root user at UID 1000 (Debian slim has no default user at this UID).
RUN useradd -m -u 1000 -s /bin/bash user
USER user
WORKDIR /home/user

# Install Claude Code CLI.
RUN curl -fsSL https://claude.ai/install.sh | bash

ENTRYPOINT ["/entrypoint.sh"]
