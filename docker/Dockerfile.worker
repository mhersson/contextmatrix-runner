FROM alpine:3.23

# Install system dependencies + Claude Code requirements (libgcc, libstdc++, ripgrep).
RUN apk add --no-cache \
    bash curl git openssh-client ca-certificates build-base jq \
    libgcc libstdc++ ripgrep \
    nodejs npm \
    github-cli

# Install Go.
ARG GO_VERSION=1.26.2
RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') && \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${ARCH}.tar.gz" \
    | tar -C /usr/local -xzf -
ENV PATH="/usr/local/go/bin:/home/user/go/bin:/home/user/.local/bin:${PATH}"

# Install gopls (Go language server for Claude Code LSP integration).
RUN GOBIN=/usr/local/go/bin go install golang.org/x/tools/gopls@latest

# Install golangci-lint.
ARG GOLANGCI_LINT_VERSION=v2.11.4
RUN curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/${GOLANGCI_LINT_VERSION}/install.sh \
    | sh -s -- -b /usr/local/bin ${GOLANGCI_LINT_VERSION}

# Copy entrypoint.
COPY entrypoint.sh /entrypoint.sh
RUN chmod 755 /entrypoint.sh

# Create non-root user at UID 1000 (Alpine has no default user at this UID).
RUN adduser -D -u 1000 -s /bin/bash user
USER user
WORKDIR /home/user

# Install Claude Code CLI.
RUN curl -fsSL https://claude.ai/install.sh | bash

ENTRYPOINT ["/entrypoint.sh"]
